{
  "name": "@saferlayer/client",
  "version": "1.1.0",
  "description": "Official Node.js client for the SaferLayer Watermark API",
  "author": "Bytelantic <support@saferlayer.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "saferlayer": "./dist/cli/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "vitest run tests/e2e",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "saferlayer",
    "watermark",
    "api",
    "client",
    "image",
    "document",
    "security"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bytelantic/saferlayer-node"
  },
  "bugs": {
    "url": "https://github.com/bytelantic/saferlayer-node/issues"
  },
  "homepage": "https://saferlayer.com",
  "dependencies": {
    "commander": "^12.1.0",
    "log-update": "^7.0.2",
    "ora": "^8.1.1",
    "p-limit": "^7.2.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
